{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mint Starter Kit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "api": {
    "examples": {
      "languages": [
        "bash",
        "python",
        "javascript",
        "node",
        "php",
        "go",
        "java",
        "ruby",
        "powershell",
        "swift"
      ]
    }
  },
  "navigation": {
      "tabs": [
          {
            "tab": "API Reference",
            "openapi": "openapi.json"
          },
          {
            "tab": "Guides",
            "groups": [
              {
                "group": "Getting Started",
                "pages": ["index", "fast", "quickstart"]
              },
              {
                "group": "Development Guides",
                "icon": "book",
                "pages": [
                  "guides/authentication",
                  "guides/caching",
                  "guides/database-optimization",
                  "guides/api-design",
                  "guides/websockets",
                  "guides/testing"
                ]
              },
              {
                "group": "Infrastructure",
                "icon": "server",
                "pages": [
                  "guides/microservices",
                  "guides/docker-kubernetes",
                  "guides/monitoring",
                  "guides/ci-cd"
                ]
              },
              {
                "group": "Account",
                "icon": "user",
                "pages": [
                  "guides/billing"
                ]
              }
            ]
          },
          {
            "tab": "Tutorials",
            "groups": [
              {
                "group": "Step-by-Step Tutorials",
                "icon": "graduation-cap",
                "pages": [
                  "tutorials/building-rest-api",
                  "tutorials/react-app"
                ]
              }
            ]
          }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://discord.gg/example",
          "icon": "discord"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/mintlify",
          "icon": "github"
        }
      ]
    }
  },
  "banner": {
    "content": "This is global banner (again)",
    "dismissible": true
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
